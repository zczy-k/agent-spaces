{
  "id": "workfox.openai",
  "name": "OpenAI",
  "version": "2.0.0",
  "description": "OpenAI 集成插件，支持文生图、图片编辑、Chat Completions、Embeddings、Audio TTS/STT",
  "author": { "name": "workfox" },
  "tags": ["AI", "图片生成", "OpenAI", "GPT", "Chat", "Embeddings", "TTS", "STT"],
  "type": "server",
  "hasWorkflow": true,
  "hasView": false,
  "entries": {
    "server": "main.js",
    "workflow": "workflow.js",
    "tools": "tools.js"
  },
  "config": [
    {
      "key": "apiKey",
      "label": "API Key",
      "desc": "OpenAI API Key",
      "type": "string",
      "value": "",
      "placeholder": "sk-...",
      "required": true
    },
    {
      "key": "baseUrl",
      "label": "API 地址",
      "desc": "OpenAI API 基础地址，支持代理",
      "type": "string",
      "value": "https://api.openai.com",
      "placeholder": "https://api.openai.com"
    }
  ]
}
