{
  "id": "workfox.ffmpeg",
  "name": "FFmpeg音视频处理",
  "version": "1.0.0",
  "description": "基于FFmpeg的音视频处理，支持格式转换、音视频合并、音视频分离",
  "author": { "name": "workfox" },
  "tags": ["FFmpeg", "音视频", "格式转换"],
  "type": "server",
  "hasWorkflow": true,
  "hasView": false,
  "entries": {
    "server": "main.js",
    "workflow": "workflow.js"
  },
  "config": [
    {
      "key": "ffmpegPath",
      "label": "FFmpeg路径",
      "desc": "FFmpeg可执行文件路径，留空则使用系统PATH中的ffmpeg",
      "type": "string",
      "value": "",
      "placeholder": "/usr/local/bin/ffmpeg"
    }
  ]
}
