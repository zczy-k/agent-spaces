{
  "id": "workfox.minimax",
  "name": "MiniMax AI",
  "version": "1.0.0",
  "description": "MiniMax AI 多模态生成，支持文本合成(M2.x大模型)、角色对话(M2-her)、语音合成(TTS)、音乐生成、视频生成(文生/图生/首尾帧/主体参考)、歌词生成",
  "author": { "name": "workfox" },
  "tags": ["AI", "文本合成", "角色对话", "语音合成", "音乐生成", "视频生成", "MiniMax", "海螺AI"],
  "type": "server",
  "hasWorkflow": true,
  "hasView": false,
  "entries": {
    "server": "main.js",
    "workflow": "workflow.js",
    "tools": "tools.js"
  },
  "config": [
    {
      "key": "apiKey",
      "label": "API Key",
      "desc": "MiniMax API Key，可在 账户管理>接口密钥 中获取",
      "type": "string",
      "value": "",
      "placeholder": "输入你的 MiniMax API Key",
      "required": true
    },
    {
      "key": "baseUrl",
      "label": "API 地址",
      "desc": "MiniMax API 服务地址",
      "type": "string",
      "value": "https://api.minimaxi.com",
      "placeholder": "https://api.minimaxi.com"
    }
  ]
}
