{
  "id": "workflow.mira-sdk",
  "name": "Mira SDK",
  "name_zh": "Mira SDK",
  "name_en": "Mira SDK",
  "version": "1.0.0",
  "description": "Mira App Server SDK，支持素材库管理、文件上传下载、插件管理、设备通信、系统监控等操作。",
  "description_zh": "Mira App Server SDK，支持素材库管理、文件上传下载、插件管理、设备通信、系统监控等操作。",
  "description_en": "Mira App Server SDK for library management, file operations, plugin management, device communication, and system monitoring.",
  "author": { "name": "workflow" },
  "tags": ["Mira", "SDK", "素材库"],
  "tags_zh": ["Mira", "SDK", "素材库"],
  "tags_en": ["Mira", "SDK", "Library"],
  "type": "server",
  "hasWorkflow": true,
  "hasView": false,
  "entries": {
    "server": "main.js",
    "workflow": "workflow.js",
    "tools": "tools.js"
  },
  "config": [
    {
      "key": "baseUrl",
      "label": "Server URL",
      "desc": "Mira App Server 地址",
      "type": "string",
      "value": "http://localhost:8081",
      "placeholder": "http://localhost:8081",
      "required": true
    },
    {
      "key": "username",
      "label": "Username",
      "desc": "登录用户名",
      "type": "string",
      "value": "",
      "required": false
    },
    {
      "key": "password",
      "label": "Password",
      "desc": "登录密码",
      "type": "string",
      "value": "",
      "required": false
    },
    {
      "key": "token",
      "label": "Token",
      "desc": "已有的认证 Token（与用户名密码二选一）",
      "type": "string",
      "value": ""
    },
    {
      "key": "timeout",
      "label": "Timeout (ms)",
      "desc": "请求超时时间（毫秒）",
      "type": "number",
      "value": 15000
    }
  ]
}
