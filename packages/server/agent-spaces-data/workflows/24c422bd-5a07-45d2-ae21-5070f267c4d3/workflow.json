    {
      "id": "node_1780885183586_bykbh6",
      "type": "run_code",
      "label": "判断文件类型",
      "position": {
        "x": 0,
        "y": 200
      },
      "data": {
        "code": "async function main({ params, context }) {\n  // 从开始节点获取上传的文件\n  const file = params.input_file;\n  // 兼容结构：可能是 { url, name, type } 也可能直接是字符串路径\n  const fileName = (file && (file.name || file.filename)) || (typeof file === 'string' ? file.split(/[\\\\\\\\/]/).pop() : '');\n  const mimeType = (file && file.type) || '';\n  const ext = (fileName || '').toLowerCase().split('.').pop();\n\n  const videoExts = ['mp4', 'mov', 'mkv', 'avi', 'flv', 'wmv', 'webm', 'm4v', 'mpeg', 'mpg', 'ts', '3gp'];\n  const audioExts = ['mp3', 'wav', 'aac', 'flac', 'ogg', 'm4a', 'wma', 'opus', 'amr', 'aiff', 'ac3'];\n\n  let fileType = 'other';\n  if (mimeType.startsWith('video/') || videoExts.includes(ext)) {\n    fileType = 'video';\n  } else if (mimeType.startsWith('audio/') || audioExts.includes(ext)) {\n    fileType = 'audio';\n  }\n\n  return {\n    file_type: fileType,\n    file_name: fileName,\n    file_ext: ext,\n    mime_type: mimeType,\n    original_file: file\n  };\n}",
        "outputs": [
          {
            "key": "file_type",
            "type": "string"
          },
          {
            "key": "file_name",
            "type": "string"
          },
          {
            "key": "file_ext",
            "type": "string"
          },
          {
            "key": "mime_type",
            "type": "string"
          }
        ]
      }
    },
