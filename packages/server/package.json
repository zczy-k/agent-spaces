{
  "name": "@agent-spaces/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "postinstall": "node -e \"try{require('node-pty')}catch(e){if(!require('fs').existsSync('node_modules/node-pty/prebuilds')){process.exit(1)}}\""
  },
  "dependencies": {
    "@agent-spaces/shared": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.2.126",
    "@codeany/open-agent-sdk": "^0.2.1",
    "@larksuiteoapi/node-sdk": "^1.62.1",
    "@openai/codex-sdk": "^0.128.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "node-pty": "^1.1.0",
    "simple-git": "^3.36.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
