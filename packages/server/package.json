{
  "name": "@agent-spaces/server",
  "version": "0.4.2",
  "type": "module",
  "bin": {
    "agent-spaces-server": "./dist/app.js"
  },
  "files": [
    "dist",
    "public",
    "!dist/**/*.map",
    "!dist/shared"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "prepublishOnly": "pnpm build",
    "postinstall": "node -e \"try{require('node-pty')}catch(e){if(!require('fs').existsSync('node_modules/node-pty/prebuilds')){process.exit(1)}}\""
  },
  "dependencies": {
    "@agent-spaces/shared": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.2.126",
    "@codeany/open-agent-sdk": "^0.2.1",
    "@dagrejs/dagre": "^3.0.0",
    "@langchain/anthropic": "^1.3.29",
    "@langchain/google-genai": "^2.1.30",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.4.5",
    "@larksuiteoapi/node-sdk": "^1.62.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@openai/codex-sdk": "^0.128.0",
    "adm-zip": "^0.5.14",
    "archiver": "^7.0.0",
    "cors": "^2.8.5",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.4.2",
    "eventemitter2": "^6.4.9",
    "express": "^5.1.0",
    "langchain": "^1.4.0",
    "minimatch": "^10.2.5",
    "multer": "^1.4.5-lts.2",
    "node-cron": "^4.2.1",
    "node-pty": "^1.1.0",
    "simple-git": "^3.36.0",
    "typescript-language-server": "^5.2.0",
    "uuid": "^11.1.0",
    "vscode-ws-jsonrpc": "^3.5.0",
    "ws": "^8.18.2",
    "yauzl": "^3.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.6",
    "@types/archiver": "^6.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/minimatch": "^6.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.39",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@types/yauzl": "^3.3.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
