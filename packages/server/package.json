{
  "name": "@agent-spaces/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "postinstall": "node -e \"require('node-pty')\" 2>/dev/null || npx node-gyp rebuild --directory=node_modules/node-pty"
  },
  "dependencies": {
    "@agent-spaces/shared": "workspace:*",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "node-pty": "^1.1.0",
    "uuid": "^11.1.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
