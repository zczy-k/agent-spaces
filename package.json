{
  "name": "agent-spaces",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"pnpm --filter @agent-spaces/server dev\" \"pnpm --filter @agent-spaces/web dev\"",
    "build": "pnpm --filter @agent-spaces/shared build && pnpm --filter @agent-spaces/server build && pnpm --filter @agent-spaces/web build",
    "build:docker:web": "docker build -f Dockerfile.web -t agent-spaces-web:latest .",
    "build:docker:server": "docker build -f Dockerfile.server -t agent-spaces-server:latest .",
    "build:docker": "pnpm build:docker:server && pnpm build:docker:web",
    "lint": "pnpm -r lint",
    "clean": "rm -rf packages/*/dist packages/*/.next"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
