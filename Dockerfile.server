FROM node:22

RUN npm config set registry https://registry.npmmirror.com && \
    npm install -g pnpm && \
    pnpm config set registry https://registry.npmmirror.com

WORKDIR /app

COPY .npmrc pnpm-workspace.yaml package.json pnpm-lock.yaml tsconfig.base.json ./
COPY packages/shared/ packages/shared/
COPY packages/server/ packages/server/

ENV CI=true

RUN node -e "const p=JSON.parse(require('fs').readFileSync('package.json','utf8'));p.pnpm={onlyBuiltDependencies:['esbuild','node-pty','protobufjs']};require('fs').writeFileSync('package.json',JSON.stringify(p,null,2))" && \
    pnpm install --frozen-lockfile && \
    pnpm --filter @agent-spaces/shared build && \
    pnpm --filter @agent-spaces/server build && \
    rm -rf packages/shared/src packages/server/src && \
    pnpm prune --prod && \
    pnpm store prune

WORKDIR /app/packages/server

ENV PORT=3100
ENV HOST=0.0.0.0
ENV NODE_ENV=production
ENV AGENT_SPACES_DATA_DIR=/root/.agent-spaces-data

EXPOSE 3100

CMD ["node", "dist/app.js"]
