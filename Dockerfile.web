FROM node:22 AS builder

RUN npm config set registry https://registry.npmmirror.com && \
    npm install -g pnpm

WORKDIR /app

COPY .npmrc pnpm-workspace.yaml package.json pnpm-lock.yaml tsconfig.base.json ./
COPY packages/shared/ packages/shared/
COPY packages/web/ packages/web/

ARG SERVER_URL=http://localhost:3100
ENV SERVER_URL=$SERVER_URL
ENV NEXT_TELEMETRY_DISABLED=1

RUN printf '\nonlyBuiltDependencies[]=esbuild\nonlyBuiltDependencies[]=sharp\n' >> .npmrc && \
    pnpm install --frozen-lockfile && \
    pnpm --filter @agent-spaces/shared build && \
    pnpm --filter @agent-spaces/web build

FROM node:22-slim AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000
ENV NEXT_TELEMETRY_DISABLED=1

RUN groupadd --gid 1001 nodejs && \
    useradd --uid 1001 --gid nodejs nextjs

COPY --from=builder /app/packages/web/.next/standalone ./
COPY --from=builder /app/packages/web/.next/static ./packages/web/.next/static
COPY --from=builder /app/packages/web/public ./packages/web/public

USER nextjs

EXPOSE 3000

CMD ["node", "packages/web/server.js"]
